{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Default capability for the Cadence tray overlay",
  "windows": ["overlay"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://clerk.cadence.aman7ph.com/*" },
        { "url": "https://*.clerk.accounts.dev/*" }
      ]
    }
  ]
}
