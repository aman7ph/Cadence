{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CadenceTray",
  "version": "0.1.0",
  "identifier": "com.cadence.tray",
  "build": {
    "beforeDevCommand": "pnpm run vite:dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "pnpm run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "CadenceTray",
        "width": 280,
        "height": 460,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "shadow": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
