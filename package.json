{
  "name": "cadence",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-platform task & habit manager — Convex + Clerk + Vite + React.",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "convex:dev": "pnpm --filter @cadence/backend dev",
    "web:dev": "pnpm --filter @cadence/web dev",
    "mobile:dev": "pnpm --filter @cadence/mobile android",
    "tray:dev": "pnpm --filter @cadence/tray dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "react-native": "0.81.5",
      "expo-crypto": "15.0.9",
      "expo-auth-session": "7.0.11",
      "expo-linking": "8.0.12",
      "expo-constants": "18.0.13",
      "react-dom": "19.1.0"
    }
  }
}
